# DeepSeek Trading Bot Environment Variables

# AI API Configuration (Required - Unified OpenAI V1 Compatible)
# 统一AI配置 - 支持任何OpenAI V1兼容的API
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 或者使用传统的DeepSeek配置（向后兼容）
# DEEPSEEK_API_KEY=your_deepseek_api_key

# === 常用AI提供商配置示例 ===
# DeepSeek - 推荐用于加密货币交易
AI_API_KEY=sk-your_actual_deepseek_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
# 优点: 专为交易场景优化，响应速度快，成本低

# OpenAI官方 - 支持GPT-4等模型
AI_API_KEY=sk-your_actual_openai_api_key
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4
# 优点: 模型选择多，API稳定

# OneAPI (中转服务，支持多个AI提供商)
AI_API_KEY=sk-your_actual_oneapi_key
AI_BASE_URL=https://your-oneapi-domain.com
AI_MODEL=gpt-4
# 优点: 统一接口，可切换不同AI提供商

# Moonshot AI (Kimi) - 长上下文模型
AI_API_KEY=sk-your_actual_moonshot_api_key
AI_BASE_URL=https://api.moonshot.cn
AI_MODEL=moonshot-v1-8k
# 优点: 中文支持好，长文本处理能力强

# 智谱AI (GLM) - 国产AI模型
AI_API_KEY=your_actual_glm_api_key
AI_BASE_URL=https://open.bigmodel.cn
AI_MODEL=glm-4
# 优点: 中文优化，符合国内使用习惯

# === AI参数配置 ===
AI_TEMPERATURE=0.1
AI_MAX_RETRIES=2
AI_TIMEOUT=10

# === 交易所配置 ===
# OKX Configuration
OKX_API_KEY=your_okx_api_key
OKX_SECRET=your_okx_secret
OKX_PASSWORD=your_okx_password

# Binance Configuration (Alternative to OKX)
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_SECRET=your_binance_secret

# === 其他配置 ===
# CryptOracle API (Optional)
# CRYPTORACLE_API_KEY=your_cryptoracle_api_key

# Trading Configuration
TRADE_SYMBOL=BTC/USDT:USDT
TRADE_LEVERAGE=10
TRADE_TIMEFRAME=15m
TRADE_TEST_MODE=true

# 日投入限额启用控制
# true: 启用日投入限额功能，将阻止超过限额的交易
# false: 禁用日投入限额功能，允许无限制交易（风险较高）
DAILY_LIMIT_ENABLE=true

# 日投入限额金额（USDT）
# 定义单日最大投入金额，超过此金额的交易将被阻止
# 建议: 小资金用户可设为100-500，中等资金设为1000-2000
DAILY_LIMIT_USDT=1000

# 日限额重置时间点（小时，24小时制）
# 每天在此时间重置投入限额计数器
# 示例: 0表示凌晨00:00重置，8表示早上08:00重置，20表示晚上20:00重置
# 时区由DAILY_LIMIT_TIMEZONE参数决定
DAILY_LIMIT_RESET_HOUR=0

# 日限额重置时区
# 控制重置时间的参考时区
# 常用时区:
#   - Asia/Shanghai (北京时间，UTC+8)
#   - Asia/Tokyo (日本时间，UTC+9)
#   - America/New_York (纽约时间，UTC-5)
#   - Europe/London (伦敦时间，UTC+0)
#   - UTC (世界协调时间)
DAILY_LIMIT_TIMEZONE=Asia/Shanghai

# 最大总敞口比例（%）
# 防止过度投入的风险控制参数，单次交易不超过总资金的此比例
# 示例: 50表示单次交易最多使用总资金的50%
DAILY_LIMIT_MAX_EXPOSURE=50

# 最小保留余额（USDT）
# 账户中必须保留的最小USDT余额，不会被用于交易
# 建议: 保留100-500 USDT作为应急资金
DAILY_LIMIT_MIN_RESERVE=100

# 日限额数据库存储路径
# SQLite数据库文件路径，保存交易记录和统计信息
# 默认存储在项目的data目录中
DAILY_LIMIT_DB_PATH=data/daily_limits.db

# 日限额警告阈值（0-1之间的数值）
# 当日投入达到此阈值比例时发出警告
# 示例: 0.8表示达到80%时警告，0.9表示达到90%时警告
DAILY_LIMIT_WARNING_THRESHOLD=0.8

# ========================================
# 智能仓位管理配置
# ========================================

# 启用智能仓位控制
# true: 启用多因子动态调整仓位（信心度、趋势强度、RSI状态、持仓状态）
# false: 使用固定仓位，每次交易投入相同金额
POSITION_INTELLIGENT=true

# 基础投入金额（USDT）
# 信心度为MEDIUM时的基础投入金额
# 将根据信心度和市场状况自动调整
POSITION_BASE_USDT=100

# 高信心度倍数
# 当AI分析信号为HIGH信心时，基础投入金额的倍数
# 示例: 1.5表示高信心时投入150 USDT (100 * 1.5)
POSITION_HIGH_MULTIPLIER=1.5

# 中信心度倍数
# 当AI分析信号为MEDIUM信心时，基础投入金额的倍数
# 示例: 1.0表示中信心时投入100 USDT (100 * 1.0)
POSITION_MEDIUM_MULTIPLIER=1.0

# 低信心度倍数
# 当AI分析信号为LOW信心时，基础投入金额的倍数
# 示例: 0.5表示低信心时投入50 USDT (100 * 0.5)
# 注意: 在有持仓的情况下，LOW信心信号可能不会执行交易
POSITION_LOW_MULTIPLIER=0.5

# 最大仓位比例（%）
# 单次交易最多使用总资金的百分比
# 示例: 10表示最多使用总资金的10%作为单次交易投入
# 防止单次交易投入过多资金的风险
POSITION_MAX_RATIO=10

# 趋势强度倍数
# 当市场趋势符合时，可以适当增加仓位
# 仅在趋势明显时生效，震荡市场使用1.0倍数
# 示例: 1.2表示强趋势时投入120% (100 * 1.2)
POSITION_TREND_MULTIPLIER=1.2

# ========================================
# 🎯 使用说明和常见问题
# ========================================

# 📋 快速配置指南
# === 1. 首次使用（推荐配置） ===
# AI配置: 只需配置DeepSeek，其他AI提供商可选
# 交易所配置: 只需配置一个交易所的API密钥
# 风险控制: 启用日投入限额 (DAILY_LIMIT_ENABLE=true)
# 测试模式: 保持测试模式 (TRADE_TEST_MODE=true)

# === 2. 切换交易所 ===
# 方法1: 修改DEFAULT_EXCHANGE参数
# DEFAULT_EXCHANGE=okx     # 强制使用OKX
# DEFAULT_EXCHANGE=binance  # 强制使用Binance
# DEFAULT_EXCHANGE=auto      # 自动检测（推荐）

# 方法2: 临时指定（代码中）
# exchange = ExchangeFactory.create_adapter('okx')

# === 3. 获取API密钥 ===
# OKX: 登录 https://www.okx.com/account/my-api
# 步骤: 创建API → 设置权限（交易权限必需）→ 复制三个密钥

# Binance: 登录 https://www.binance.com/zh-CN/my/settings/api-management
# 步骤: 创建API → 权限设置（现货/期货交易权限）→ 复制两个密钥

# === 4. 测试配置 ===
# 1. 复制此文件为.env: copy .env.example .env
# 2. 编辑.env文件，填入您的API密钥
# 3. 运行测试: python main.py --mode test
# 4. 查看输出确认配置正确

# === 5. 常见错误和解决方案 ===
# 错误1: "缺少必需的API密钥"
# 解决: 检查.env文件中对应交易所的API密钥是否完整

# 错误2: "不支持的交易所"
# 解决: 检查DEFAULT_EXCHANGE参数值是否正确（okx/binance/auto）

# 错误3: "数据库初始化失败"
# 解决: 确保data目录存在，或修改DAILY_LIMIT_DB_PATH路径

# 错误4: "余额不足"
# 解决: 检查交易所账户中是否有足够USDT余额

# === 6. 安全提示 ===
# 🔒 API密钥安全:
# - 永不在代码中硬编码API密钥
# - 使用专用的交易账户（不要使用主账户）
# - 定期更换API密钥（建议每月更换）
# - 设置IP白名单限制API访问

# 💰 资金安全:
# - 首次使用务必启用TEST_MODE
# - 建议初始资金不超过账户余额的10%
# - 设置合理的止损止盈参数
# - 定期检查交易日志和余额

# ⚠️ 风险警告:
# - 加密货币交易存在资金损失风险
# - 高杠杆交易可能造成快速亏损
# - 市场波动剧烈时建议暂停交易
# - 本项目仅供学习参考，不构成投资建议

# ========================================
# 📞 技术支持
# ========================================
# 项目地址: https://github.com/your-repo/deepseek-trading-bot
# 问题反馈: 提交Issue到GitHub仓库
# 更多文档: 查看docs/目录下的详细文档

