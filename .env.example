# ========================================
# 🔧 高级配置参数（v5.0新增）
# ========================================

# === 技术指标阈值配置 ===
# 最小数据点数 - 计算技术指标所需的最小K线数量
INDICATOR_MIN_DATA_POINTS=20

# RSI指标阈值
INDICATOR_RSI_NEUTRAL=50.0        # RSI中性值
INDICATOR_RSI_OVERBOUGHT=70.0     # RSI超买阈值（高于此值视为超买）
INDICATOR_RSI_OVERSOLD=30.0       # RSI超卖阈值（低于此值视为超卖）

# 布林带位置阈值
INDICATOR_BB_OVERBOUGHT=0.8       # 布林带超买位置（接近上轨）
INDICATOR_BB_OVERSOLD=0.2         # 布林带超卖位置（接近下轨）
INDICATOR_BB_NEUTRAL=0.5          # 布林带中性位置

# 成交量判断阈值
VOLUME_HIGH_THRESHOLD=1.5         # 高成交量倍数（相对均值）
VOLUME_LOW_THRESHOLD=0.5          # 低成交量倍数（相对均值）

# 支撑阻力位默认比例
SUPPORT_RESISTANCE_DEFAULT_PCT=0.05  # 默认5%作为支撑阻力位偏移

# 趋势判断阈值（评分系统）
TREND_STRONG_UP_THRESHOLD=4       # 强势上涨阈值
TREND_UP_THRESHOLD=2              # 上涨阈值
TREND_DOWN_THRESHOLD=-2           # 下跌阈值
TREND_STRONG_DOWN_THRESHOLD=-4    # 强势下跌阈值

# === AI分析高级参数 ===
# 重试机制配置
AI_RETRY_BACKOFF_BASE=2           # 指数退避基数（2^retry_count）
AI_RETRY_MAX_WAIT=10              # 单次重试最长等待时间（秒）

# AI分析数据量
AI_KLINE_DISPLAY_COUNT=5          # 发送给AI的K线数量
AI_SIGNAL_HISTORY_COUNT=3         # 包含在分析中的历史信号数

# === 仓位管理高级参数 ===
# 固定仓位模式配置
POSITION_FIXED_CONTRACTS=0.1      # 禁用智能仓位时的固定合约数量

# RSI极端值仓位调整
POSITION_RSI_EXTREME_HIGH=75.0    # 极端高RSI阈值
POSITION_RSI_EXTREME_LOW=25.0     # 极端低RSI阈值
POSITION_RSI_EXTREME_MULTIPLIER=0.7  # 极端RSI时的仓位调整倍数（减仓）

# 加仓策略
POSITION_ADD_MULTIPLIER=1.2       # 同向加仓时的倍数

# === 风险控制参数 ===
# 单次交易风险限制
RISK_MAX_LOSS_PCT=5.0             # 单次最大损失百分比（占总资金）
RISK_MIN_REWARD_RATIO=1.0         # 最小风险收益比（止盈/止损比例）

# 默认止损止盈
DEFAULT_STOP_LOSS_PCT=0.02        # 默认止损百分比（2%）
DEFAULT_TAKE_PROFIT_PCT=0.02      # 默认止盈百分比（2%）

# === 防频繁交易配置 ===
# 时间间隔保护
FREQUENCY_MIN_INTERVAL_MINUTES=15 # 两次交易之间的最小时间间隔（分钟）

# 信号历史管理
FREQUENCY_MAX_HISTORY=50          # 保留的信号历史数量

# 连续信号保护
FREQUENCY_CONSECUTIVE_LIMIT=3     # 连续相同信号的最大数量
FREQUENCY_HOLD_CONFIRM_PERIODS=2  # HOLD信号后需要的确认周期数

# 信号反转频率限制
FREQUENCY_REVERSAL_WINDOW=10      # 检查信号反转的窗口大小
FREQUENCY_MAX_REVERSALS=4         # 窗口内允许的最大反转次数

# === 订单执行配置 ===
# 订单历史管理
ORDER_MAX_HISTORY=100             # 保留的订单历史记录数量

# 订单执行等待
ORDER_WAIT_SECONDS=2              # 创建订单后等待生效的时间（秒）

# 订单标签（用于识别和追踪）
ORDER_TAG_OPEN=deepseek_bot       # 开仓订单标签
ORDER_TAG_CLOSE=deepseek_bot_close  # 平仓订单标签

# === 备用信号生成器配置 ===
# 历史管理
FALLBACK_MAX_HISTORY=30           # 备用生成器的信号历史容量

# 评分权重
FALLBACK_TREND_WEIGHT=1.5         # 趋势因素的评分权重
FALLBACK_VOLUME_WEIGHT=0.5        # 成交量因素的评分权重

# 信号判断阈值
FALLBACK_BUY_THRESHOLD=2.0        # 买入信号总分阈值
FALLBACK_SELL_THRESHOLD=-2.0      # 卖出信号总分阈值

# 止损止盈设置
FALLBACK_STOP_LOSS_PCT=0.02       # 备用信号默认止损百分比（2%）
FALLBACK_TAKE_PROFIT_PCT=0.04     # 备用信号默认止盈百分比（4%）

# 信心度判断
FALLBACK_HIGH_CONFIDENCE_THRESHOLD=3.0    # 高信心度评分阈值
FALLBACK_MEDIUM_CONFIDENCE_THRESHOLD=1.0  # 中信心度评分阈值

# === 交易引擎配置 ===
# 信号历史管理
ENGINE_SIGNAL_HISTORY_MAX=30      # 引擎保留的信号历史数量
ENGINE_SIGNAL_CONTEXT_COUNT=3     # 提供给AI的历史信号数

# === 定时调度配置 ===
# 默认执行间隔
SCHEDULER_DEFAULT_INTERVAL_SECONDS=900  # 默认执行间隔（秒）- 15分钟

# ========================================
# 📝 配置说明
# ========================================
# 以上高级参数已设置为推荐默认值
# 大多数用户无需修改这些参数
# 如需调优策略，可根据实际交易表现逐步调整
# 建议在测试模式下验证参数变更效果

